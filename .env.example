# Font Server Environment Variables

# PUBLIC_URL: The base URL where fonts are publicly accessible.
# Used to generate absolute URLs in @font-face CSS and JSON responses.
# Example: https://yourdomain.vercel.app
# IMPORTANT: Set this in Vercel dashboard via Settings > Environment Variables
PUBLIC_URL=https://yourdomain.vercel.app

# ALLOWED_ORIGINS: CORS allowed origins (comma-separated or "*" for all).
# Applied to dynamic routes (/api/fonts.css, /api/fonts/list, /api/health).
# Static assets have separate CORS headers in vercel.json.
# Default: "*" (allow all origins)
ALLOWED_ORIGINS=*

# FONTS_DIR: Relative path to the fonts directory.
# Must contain subdirectories for font families.
# Example structure:
#   public/fonts/
#     Inter/
#       Inter-Regular.woff2
#       Inter-Bold.woff2
#     Lora/
#       Lora-Italic.woff2
# Default: public/fonts
FONTS_DIR=public/fonts

# NODE_ENV: Deployment environment.
# Set to "production" on Vercel (done automatically).
# Set to "development" for local dev.
NODE_ENV=development

# PORT: Local development server port (only used by dev-server.ts with Bun).
# Not used on Vercel (which assigns ports dynamically).
# Default: 3000
PORT=3000

# HOST: Local development server host.
# Not used on Vercel.
# Default: localhost
HOST=localhost
